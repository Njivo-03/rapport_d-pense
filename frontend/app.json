{
  "expo": {
    "name": "Expense Report",
    "slug": "expense-report",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#FFFFFF"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.expensereport.mobile"
    },
    "plugins": [
      "expo-asset",
      "expo-font"
    ]
  }
}
